# Asana Integration (optional - omit to use mock data)
# Generate a Personal Access Token at https://app.asana.com/0/developer-console
ASANA_PAT=
ASANA_WORKSPACE_ID=39418109315600

# Comma-separated Asana project GIDs to display in the portal
# Leave empty to show all workspace projects
ASANA_PROJECT_IDS=

# Azure SQL Database (optional - omit to use mock order data)
# Format: Server=myserver.database.windows.net;Database=mydb;User Id=user;Password=pass;Encrypt=true;TrustServerCertificate=false;
AZURE_SQL_CONNECTION_STRING=

# Google Sheets Integration (optional - omit to use mock schedule data)
# Service account credentials from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Spreadsheet ID from the Google Sheets URL (between /d/ and /edit)
GOOGLE_SHEET_ID=
# Tab name to read (e.g. "Batch Schedule 0313")
GOOGLE_SHEET_NAME=
